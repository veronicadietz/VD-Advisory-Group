  nav {
    padding: 22px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--hair);
  }
  .nav-brand {
    font-family: 'Playfair Display', serif;
    font-size: 17px;
    font-weight: 500;
    color: var(--forest);
    text-decoration: none;
  }
  .nav-brand em { font-style: italic; color: var(--burnt); font-weight: 400; }
  .nav-back {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--forest);
    font-weight: 500;
    text-decoration: none;
    border: 1px solid var(--forest);
    padding: 10px 20px;
    transition: all 0.3s;
  }
  .nav-back:hover { background: var(--forest); color: var(--cream); }
  main {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px 40px;
  }
  .content {
    max-width: 640px;
    text-align: center;
  }
  .eyebrow {
    font-size: 11px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--burnt);
    font-weight: 500;
    margin-bottom: 36px;
    display: inline-flex;
    align-items: center;
    gap: 14px;
  }
  .eyebrow::before, .eyebrow::after {
    content: '';
    width: 40px;
    height: 1px;
    background: var(--burnt);
  }
  h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(56px, 10vw, 120px);
    font-weight: 400;
    line-height: 1;
    color: var(--forest);
    margin-bottom: 32px;
    letter-spacing: -0.02em;
  }
  h1 em { font-style: italic; color: var(--burnt); }
  .lede {
    font-family: 'Playfair Display', serif;
    font-size: 26px;
    font-style: italic;
    color: var(--forest);
    line-height: 1.4;
    margin-bottom: 24px;
    font-weight: 400;
  }
  p {
    font-size: 17px;
    line-height: 1.7;
    color: var(--muted);
    margin-bottom: 40px;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }
  .ctas {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 28px;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.3s;
    border: 1px solid var(--forest);
  }
  .btn-primary { background: var(--forest); color: var(--cream); }
  .btn-primary:hover { background: var(--burnt); border-color: var(--burnt); }
  .btn-secondary { background: transparent; color: var(--forest); }
  .btn-secondary:hover { background: var(--forest); color: var(--cream); }
  footer {
    padding: 32px 40px;
    border-top: 1px solid var(--hair);
    font-size: 12px;
    color: var(--muted);
    text-align: center;
  }
  @media (max-width: 600px) {
    nav { padding: 18px 24px; }
    main { padding: 60px 24px; }
  }
</style>
</head>
<body>
<nav>
  <a href="/" class="nav-brand">VD <em>Advisory</em> Group</a>
  <a href="/" class="nav-back">← Home</a>
</nav>
<main>
