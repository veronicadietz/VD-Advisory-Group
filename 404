    <div class="ctas">
      <a href="/" class="btn btn-primary">Back to the practice</a>
      <a href="https://start.veronicadietz.com/" class="btn btn-secondary">Start with the free diagnostic</a>
    </div>
  </div>
</main>
<footer>© 2026 VD Advisory Group</footer>
